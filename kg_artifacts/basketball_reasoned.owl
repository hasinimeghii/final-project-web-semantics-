                  <swrl:argument1 rdf:resource="urn:swrl#t"/>
                </swrl:ClassAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#scored_in"/>
                      <swrl:argument1 rdf:resource="urn:swrl#x"/>
                      <swrl:argument2 rdf:resource="urn:swrl#g"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <rdf:Description>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
