                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:first>
                            <swrl:DifferentIndividualsAtom>
                              <swrl:argument1 rdf:resource="urn:swrl#x"/>
                              <swrl:argument2 rdf:resource="urn:swrl#y"/>
                            </swrl:DifferentIndividualsAtom>
                          </rdf:first>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                        </rdf:Description>
