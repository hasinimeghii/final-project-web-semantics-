                          <swrl:argument1 rdf:resource="urn:swrl#g"/>
                          <swrl:argument2 rdf:resource="urn:swrl#t"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                  </rdf:rest>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#scored_against"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#t"/>
