<swrl:Variable rdf:about="urn:swrl#x"/>

<swrl:Variable rdf:about="urn:swrl#t"/>

<swrl:Variable rdf:about="urn:swrl#y"/>

<swrl:Variable rdf:about="urn:swrl#g"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Player"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:ClassAtom>
              <swrl:classPredicate rdf:resource="#Game"/>
              <swrl:argument1 rdf:resource="urn:swrl#g"/>
            </swrl:ClassAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
